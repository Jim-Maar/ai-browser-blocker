{
  "name": "ai-browser-blocker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/ && knip",
    "fix": "eslint src/ --fix && prettier --write src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-web-extension": "^4.1.1"
  }
}
